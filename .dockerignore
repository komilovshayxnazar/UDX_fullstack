.env
.env.local
.env.development
.env.production
.env.staging

# Docs + audit — not needed inside the image
BUGS.md
RUN_PROJECT.md
NEO4J_SETUP.md
README.md
Icon/

# Compose config itself
docker-compose*.yml
Dockerfile
docker/
