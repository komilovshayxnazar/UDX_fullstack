# Frontend build context — keep it lean.
.git/
.gitignore
.vscode/
.idea/
node_modules/
build/
dist/
.DS_Store
Thumbs.db
*.log
nohup.out

# Backend + Android are built by their own contexts / not by the frontend.
backend/
android_app/
tests/

