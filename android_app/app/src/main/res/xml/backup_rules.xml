<?xml version="1.0" encoding="utf-8"?>
<!--
    Legacy Auto Backup rules (Android <= 11). We opt out of backing up
    auth tokens and any other sensitive SharedPreferences so `adb backup`
    can't extract them from a rooted device.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="auth_prefs.xml" />
</full-backup-content>
