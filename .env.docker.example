# Environment matrix consumed by docker-compose.yml.
#
#   cp .env.docker.example .env.docker
#   # …edit the required values below…
#   docker compose --env-file .env.docker up -d
#
# The `${VAR:?message}` interpolation in docker-compose.yml refuses to
# start any service whose required variable is missing, so a forgotten
# secret fails loudly at `up`, not at the first request.

# ─── Deployment mode ──────────────────────────────────────────────────
# "production" enables all fail-closed startup checks in backend/main.py.
ENVIRONMENT=production

# ─── Backend crypto — REQUIRED ────────────────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ENCRYPTION_KEY=
HMAC_KEY=

# ─── PostgreSQL — REQUIRED ────────────────────────────────────────────
POSTGRES_USER=udx
POSTGRES_PASSWORD=
POSTGRES_DB=udx

# ─── Redis — REQUIRED (CSRF/cache state; secondary OTP/session fallback
# behind memdb) ─────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ─── memdb (In-Memory database with WAL) ──────────────────────────────
# No secret required — internal-network-only TCP service (see the
# `memdb` compose service). MEMDB_HOST/PORT are set for you in
# docker-compose.yml; nothing to fill in here unless you're overriding
# host/port for a non-compose deployment.

# ─── Dynamic Rate Limiter gateway ──────────────────────────────────────
# Tunables for the Go gateway sitting in front of the backend (see the
# `gateway` compose service). Defaults are reasonable for a small
# marketplace; raise GATEWAY_RATE/BURST if legitimate traffic starts
# tripping 429s.
GATEWAY_RATE=20
GATEWAY_BURST=40
GATEWAY_CB_MIN_REQUESTS=5
GATEWAY_CB_FAILURE_RATIO=0.5
GATEWAY_CB_WINDOW=10s
GATEWAY_CB_COOLDOWN=5s
GATEWAY_UPSTREAM_TIMEOUT=10s

# ─── CORS + frontend build ────────────────────────────────────────────
# Nginx proxies /api/* to backend so the browser only ever hits this
# host. If you serve the frontend from a different origin, add it here.
ALLOWED_ORIGINS=https://udx-marketplace.store
FRONTEND_HTTP_PORT=8080
# Empty ("/api") = same-origin. Only override if the browser talks to
# a bare backend URL.
VITE_API_URL=/api

# ─── Payment gateway ──────────────────────────────────────────────────
# Real integration URL (leave empty in staging to also set PAYMENT_ALLOW_MOCK=1)
PAYMENT_GATEWAY_URL=
# Setting to "1" allows the mock gateway to succeed in production. Use
# only for smoke tests — production traffic MUST NOT run with this on.
PAYMENT_ALLOW_MOCK=

# ─── Click (optional) ─────────────────────────────────────────────────
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
CLICK_MERCHANT_USER_ID=
CLICK_RETURN_URL=

# ─── Google OAuth (optional but recommended) ──────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ─── Telegram bot (for OTP delivery) ──────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── Weather ──────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=

# ─── Cloudflare R2 object storage (falls back to local /uploads/) ─────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ─── Observability ────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Dev-router admin token (only relevant when ENVIRONMENT!=production)
DEV_ADMIN_TOKEN=

# ─── JWT tunables ─────────────────────────────────────────────────────
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
