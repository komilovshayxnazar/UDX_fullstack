# MongoDB Database Configuration
MONGODB_URL=mongodb://localhost:27017/udx

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# JWT Security — MUHIM: production'da kuchli kalit ishlating!
# Yaratish: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_KEY_MIN_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Muhit: development | production
# production'da /dev/* router o'chiriladi
ENVIRONMENT=development

# OpenWeatherMap API
# Get your free API key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweathermap-api-key

# Telegram Bot (OTP delivery)
# Create a bot via @BotFather on Telegram, then paste the token here
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Redis Cache (ixtiyoriy — yo'q bo'lsa cache o'chirilgan holda ishlaydi)
# REDIS_URL=redis://localhost:6379/0

# Cloudflare R2 Storage (ixtiyoriy — yo'q bo'lsa lokal /uploads/ ishlatiladi)
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET_NAME=udx-media
# R2_PUBLIC_URL=https://media.udx.uz

# Sentry Error Tracking (ixtiyoriy)
# SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
